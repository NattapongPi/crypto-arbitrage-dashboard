{
  "compilerOptions": {
    "lib": ["esnext", "dom"],
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "dist",
    "noEmit": false,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["server.ts", "lib/server/**/*.ts", "lib/types.ts", "lib/constants.ts"]
}
